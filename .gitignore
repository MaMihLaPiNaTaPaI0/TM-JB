# ================= 系统级文件 ================= #
.DS_Store
Thumbs.db
ehthumbs.db              # Windows缩略图缓存
Desktop.ini              # Windows文件夹配置
._*                      # macOS资源派生文件
.Spotlight*              # macOS索引文件
.Trashes                 # macOS垃圾桶
.lock-wscript            # node-waf配置

# ================= 日志与诊断 ================= #
*.log
*.tmp
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
logs/                    # 日志目录
*.pid                    # 进程ID文件
*.seed                   # 随机种子
*.pid.lock               # PID锁定文件
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json  # Node.js诊断报告

# ================= 敏感数据防护 ================= #
# 环境变量
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# 密钥文件
*.key
*.secret
*.pem                    # SSL私钥
*.keystore               # Java密钥库
*.jks                    # Java密钥存储
*.pfx                    # PKCS#12证书
*.cert                   # 证书文件
*.auth                   # 认证配置
*.tokens                 # API令牌集
*.credentials            # 云服务凭据
*.gpg                    # GPG加密文件

# 语义级防护
*_secret*                # 所有含"secret"的文件
*_password*              # 所有含"password"的文件
*_token*                 # 所有含"token"的文件
*_credential*            # 所有含"credential"的文件

# ================= 依赖管理 ================= #
node_modules/
jspm_packages/
web_modules/             # Snowpack依赖
bower_components/        # Bower依赖
.npm                     # npm缓存
.yarn-integrity          # Yarn校验文件
.yarn/cache              # Yarn 2缓存
.yarn/unplugged          # Yarn 2未插件包
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*                   # Yarn PnP文件
package-lock.json
yarn.lock
pnpm-lock.yaml
shrinkwrap.yaml

# ================= 构建系统 ================= #
# 通用构建输出
build/
dist/
out/
*.tgz                    # npm包输出

# 框架特定
.next/                   # Next.js
.nuxt/                   # Nuxt.js
.vuepress/dist           # VuePress
.serverless/             # Serverless
.serverless_nextjs/      # Serverless Next.js
.fusebox/                # FuseBox
.gatsby/                 # Gatsby缓存
.vitepress/dist          # VitePress
.vitepress/cache

# 缓存目录
.cache/
.parcel-cache/
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.dynamodb/               # DynamoDB本地

# TypeScript
*.tsbuildinfo            # TS构建信息

# ================= 测试覆盖率 ================= #
coverage/                # 覆盖率目录
*.lcov                   # LCOV覆盖率数据
.nyc_output              # NYC测试覆盖率
lib-cov/                 # jscoverage/JSCover

# ================= 开发工具 ================= #
# IDE配置
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/                   # JetBrains IDE
*.code-workspace         # VSCode工作区

# 编辑器历史
.node_repl_history       # Node REPL历史
.tern-port               # TernJS端口文件

# 开发缓存
.eslintcache             # ESLint缓存
.stylelintcache          # Stylelint缓存
.grunt/                  # Grunt中间存储

# ================= 配置文件 ================= #
config.ini                # 通用INI配置
settings.plist            # macOS属性列表
*.config.js               # JS配置文件
application.yml           # Spring配置
.vscode-test              # VSCode测试版本

# ================= 云服务安全 ================= #
.aws/credentials          # AWS凭证
.gcloud/configurations/*  # GCP配置
azure/config              # Azure配置

# ================= 文档系统 ================= #
.docusaurus/             # Docusaurus生成文件
